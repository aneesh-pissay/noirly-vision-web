# Noirly Vision environment template
# Copy to .env.local and fill in values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
MONGODB_URI=

# Email (Nodemailer)
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=587

# Auth
JWT_SECRET=

# Firebase Web (client push)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin (server push) — use ONE of:
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase/service-account.json

# Notification scheduler (node-cron, runs on server startup)
# Set to false to disable background notification jobs
NOTIFICATION_SCHEDULER_ENABLED=true
